# ============================================================================
# Sellora — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.

# PostgreSQL Database (Neon — get free at https://neon.tech)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# JWT Secret (change this in production! Use a long random string)
JWT_SECRET=sellora-dev-secret-change-in-production

# LLM Provider: "groq" (free) or "openai" (paid)
LLM_PROVIDER=groq

# Groq API Key (free at https://console.groq.com)
GROQ_API_KEY=

# OpenAI API Key (optional — only needed for GPT-4o, DALL-E, vision features)
OPENAI_API_KEY=

# Cloudinary (optional — for image uploads, get free at https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Server Port (default 3000)
PORT=3000
